APP_ENV=docker
APP_VERSION=0.1.0

CARENEST_MYSQL_PORT=3306
CARENEST_MYSQL_DATABASE=smart_nursing
CARENEST_MYSQL_USER=smart_nursing
CARENEST_MYSQL_PASSWORD=change-me-database
CARENEST_MYSQL_ROOT_PASSWORD=change-me-root

REDIS_PORT=6379
REDIS_PASSWORD=

MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_BUCKET=smart-nursing
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-minio
MINIO_REGION=us-east-1

JWT_SECRET=change-me-at-least-32-characters
JWT_EXPIRE_HOURS=24

BACKEND_USER_PORT=8081
BACKEND_CARE_ADMIN_PORT=8082
FRONTEND_PORT=3000

# Alibaba Cloud Model Studio (Bailian/Qwen). Keep the real key only in .env.
AI_PROVIDER=cloud
AI_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=change-me-bailian-api-key
AI_MODEL=qwen-plus
AI_TIMEOUT=15s
