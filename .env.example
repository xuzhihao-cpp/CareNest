APP_ENV=local
APP_VERSION=0.1.0

# Local processes use localhost. Docker Compose overrides container-to-container hosts.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=smart_nursing
MYSQL_USER=smart_nursing
MYSQL_PASSWORD=change-me-database
MYSQL_ROOT_PASSWORD=change-me-root

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_BUCKET=smart-nursing
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-minio

JWT_SECRET=change-me-at-least-32-characters
JWT_EXPIRE_HOURS=24

BACKEND_USER_PORT=8081
BACKEND_CARE_ADMIN_PORT=8082
FRONTEND_PORT=3000
BACKEND_USER_BASE_URL=http://localhost:8081
BACKEND_CARE_ADMIN_BASE_URL=http://localhost:8082
FRONTEND_API_BASE=/api/v1

# AI defaults to the deterministic local safety provider. Set provider to cloud
# only when an OpenAI-compatible endpoint and a valid key are available.
AI_PROVIDER=rule
AI_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=
AI_MODEL=qwen-plus
AI_TIMEOUT=15s
